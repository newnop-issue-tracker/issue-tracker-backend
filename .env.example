# Server
NODE_ENV=development
PORT=8080

# Database (MySQL)
# Local:  mysql://root:password@localhost:3306/issue_tracker
# AWS RDS: mysql://admin:password@xxx.rds.amazonaws.com:3306/issue_tracker
DATABASE_URL="mysql://root:password@localhost:3306/issue_tracker"

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=replace_me_with_a_random_32_char_secret
JWT_REFRESH_SECRET=replace_me_with_a_different_random_32_char_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Bcrypt
BCRYPT_ROUNDS=12
